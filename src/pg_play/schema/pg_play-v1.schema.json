{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/O2eg/pg_play/schema/pg_play-v1.schema.json",
  "title": "pg_play PostgreSQL experiment manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "kind", "metadata", "spec"],
  "properties": {
    "api_version": {"const": "pg_play/v1"},
    "kind": {"const": "PostgreSQLExperiment"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{1,62}$"}
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stand", "workload"],
      "properties": {
        "artifact_root": {"type": "string", "minLength": 1},
        "stand": {
          "type": "object",
          "additionalProperties": false,
          "required": ["config"],
          "properties": {
            "config": {"type": "string", "minLength": 1},
            "project": {"type": "string", "minLength": 1}
          }
        },
        "configurator": {
          "type": "object",
          "additionalProperties": false,
          "properties": {"inputs": {"type": "object"}}
        },
        "workload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["project", "profiles"],
          "properties": {
            "project": {"type": "string", "minLength": 1},
            "profiles": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            },
            "scale": {"type": "number", "exclusiveMinimum": 0},
            "database": {"type": "string", "minLength": 1},
            "user": {"type": "string", "minLength": 1},
            "install": {"type": "boolean"},
            "stop_after_report": {"type": "boolean"},
            "pgbench_duration_seconds": {"type": "integer", "minimum": 1},
            "job_interval_seconds": {"type": "integer", "minimum": 1},
            "resource_guard": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "disk_max_used_pct": {"type": "integer", "minimum": 0, "maximum": 100},
                "mem_min_available_pct": {"type": "integer", "minimum": 0, "maximum": 100},
                "mem_min_available_mb": {"type": "integer", "minimum": 0},
                "cpu_max_pct": {"type": "integer", "minimum": 0, "maximum": 100},
                "cpu_window_seconds": {"type": "integer", "minimum": 1},
                "check_interval": {"type": "integer", "minimum": 1}
              }
            }
          }
        },
        "diagnostics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {"enum": ["one-shot", "snapshots"]},
            "collection_mode": {"enum": ["remote-db-only", "local", "remote"]},
            "duration_seconds": {"type": "number", "minimum": 30, "maximum": 86400},
            "interval_seconds": {"type": "number", "minimum": 5, "maximum": 600},
            "report_name": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"}
          },
          "allOf": [
            {
              "if": {"properties": {"mode": {"const": "one-shot"}}, "required": ["mode"]},
              "then": {
                "not": {
                  "anyOf": [
                    {"required": ["duration_seconds"]},
                    {"required": ["interval_seconds"]}
                  ]
                }
              }
            }
          ]
        },
        "benchmark": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "database": {"type": "string", "minLength": 1},
            "report_name": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"},
            "benchmark_type": {"enum": ["default", "custom"]},
            "workload_profile": {"enum": ["imdb", "pagila"]},
            "workload_scale": {"type": "number", "exclusiveMinimum": 0},
            "workload_duration_seconds": {"type": "integer", "minimum": 1},
            "clients": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "integer", "minimum": 1}
            },
            "times_seconds": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "integer", "minimum": 1}
            },
            "init_command": {"type": "string", "minLength": 1},
            "workload_command": {"type": "string", "minLength": 1},
            "workload_path": {"type": "string", "minLength": 1},
            "pgbench_path": {"type": "string", "minLength": 1},
            "psql_path": {"type": "string", "minLength": 1},
            "command_timeout": {"type": "number", "exclusiveMinimum": 0},
            "system_metrics_interval": {"type": "number", "exclusiveMinimum": 0},
            "system_metrics_duration": {"type": "number", "exclusiveMinimum": 0},
            "drop_os_caches": {"type": "boolean"},
            "collect_pg_logs": {"type": "boolean"}
          },
          "oneOf": [
            {"required": ["clients"], "not": {"required": ["times_seconds"]}},
            {"required": ["times_seconds"], "not": {"required": ["clients"]}}
          ],
          "allOf": [
            {
              "if": {
                "required": ["workload_profile"]
              },
              "then": {
                "properties": {"benchmark_type": {"const": "custom"}},
                "required": ["clients"],
                "not": {
                  "anyOf": [
                    {"required": ["times_seconds"]},
                    {"required": ["workload_path"]}
                  ]
                }
              },
              "else": {"required": ["init_command", "workload_command"]}
            },
            {
              "if": {
                "allOf": [
                  {
                    "properties": {"benchmark_type": {"const": "custom"}},
                    "required": ["benchmark_type"]
                  },
                  {"not": {"required": ["workload_profile"]}}
                ]
              },
              "then": {"required": ["workload_path"]}
            }
          ]
        },
        "phases": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "benchmark": {"type": "boolean"},
            "workload_diagnostics": {"type": "boolean"},
            "recreate_workload_database": {"type": "boolean"}
          }
        }
      }
    }
  }
}
